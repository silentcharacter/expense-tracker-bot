# ──────────────────────────────────────────────────────────────────────────────
# expense-bot — environment variables for Google Cloud Functions
# Copy this file to .env.yaml and fill in the real values.
# NEVER commit .env.yaml to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN: "1234567890:ABCDefGhIjKlMnOpQrStUvWxYz"

# Optional: secret token for webhook verification (set via setWebhook?secret_token=)
# Telegram sends this in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET: ""

# ── Google AI (Gemini) ────────────────────────────────────────────────────────

# API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY: "AIzaSy..."

# ── Google Sheets / Drive ─────────────────────────────────────────────────────

# ID of the Master Registry Spreadsheet
# (the sheet that stores all user records; you create this once)
REGISTRY_SHEET_ID: "1aBcDeFgHiJkLmNoPqRsTuVwXyZ"

# ID of the template Spreadsheet to copy for each new user
TEMPLATE_SHEET_ID: "1tEmPlAtEiDxxx"

# ID of the Google Drive folder where user Spreadsheets are created
USERS_FOLDER_ID: "1FoLdErIdXxx"

# Google account that owns all user Spreadsheets
ADMIN_EMAIL: "admin@example.com"

# Email of the Service Account (so new spreadsheets can be shared with it)
SA_EMAIL: "expense-bot-sa@your-project.iam.gserviceaccount.com"

# ── Admin OAuth2 (for Drive file creation) ───────────────────────────────
# SA on consumer GCP projects has zero Drive storage, so we use the admin's
# personal Google account for copy/create operations.
# Run: python scripts/get_oauth_token.py
GOOGLE_OAUTH_CLIENT_ID: "123456789-xxx.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET: "GOCSPX-..."
GOOGLE_OAUTH_REFRESH_TOKEN: "1//0..."

# ── Exchange Rate API ─────────────────────────────────────────────────────────

# Free API key from https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY: "abcdef1234567890"

# ── Local Development ─────────────────────────────────────────────────────────

# ngrok static domain for Mini App dev (optional, avoids random URLs)
# Get a free one at https://dashboard.ngrok.com/domains → New Domain
NGROK_DOMAIN: ""

# ── Misc ──────────────────────────────────────────────────────────────────────

# IANA timezone used for date calculations (e.g. /today, /month)
TIMEZONE: "Asia/Bangkok"

# Optional: comma-separated list of allowed Telegram user IDs (leave empty for open registration)
# Example: "123456789,987654321"
ALLOWED_USER_IDS: ""

CRON_SECRET: "<random-string>"